{% assign threshold = section.settings.free_shipping_threshold | default: 100 %}
{% assign cart_total = cart.total_price | divided_by: 100.0 %}
{% assign progress = cart_total | divided_by: threshold | times: 100 %}
{% assign remaining = threshold | minus: cart_total %}

<div class="shipping-progress-bar">
  {% if cart_total >= threshold %}
    <p class="progress-message success">
      🎉 You have unlocked free shipping!
    </p>
  {% else %}
    <p class="progress-message">
      Spend <strong>{{ remaining | money }}</strong> more to unlock free shipping
    </p>
  {% endif %}

  <div class="progress-track">
    <div
      class="progress-fill {% if cart_total >= threshold %}complete{% endif %}"
      style="width: {{ progress | at_most: 100 }}%">
    </div>
  </div>

  <div class="progress-labels">
    <span>$0</span>
    <span>${{ threshold }}</span>
  </div>
</div>
