{% assign product_type = product.type | downcase %}
{% assign meta_value = product.metafields.custom.highlight_text %}
{% assign badge_value = product.metafields.custom.badge_label %}
{% assign specs = product.metafields.custom.specifications %}

{% if meta_value != blank %}
  <div class="metafield-highlight">
    <p>{{ meta_value }}</p>
  </div>
{% endif %}

{% if badge_value != blank %}
  <div class="product-badge">
    <span class="badge-label">{{ badge_value }}</span>
  </div>
{% endif %}

{% if specs != blank %}
  <div class="product-specs">
    <h4>Specifications</h4>
    {% assign spec_list = specs | split: '|' %}
    {% for spec in spec_list %}
      {% assign spec_parts = spec | split: ':' %}
      <div class="spec-row">
        <span class="spec-key">{{ spec_parts[0] }}</span>
        <span class="spec-value">{{ spec_parts[1] }}</span>
      </div>
    {% endfor %}
  </div>
{% endif %}

{% case product_type %}
  {% when 'clothing' %}
    <div class="size-guide-link">
      <a href="/pages/size-guide">View Size Guide</a>
    </div>
  {% when 'electronics' %}
    <div class="warranty-info">
      <p>{{ product.metafields.custom.warranty_info }}</p>
    </div>
  {% when 'bundle' %}
    <div class="bundle-contents">
      <p>{{ product.metafields.custom.bundle_items }}</p>
    </div>
{% endcase %}
